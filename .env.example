# ============================================================================
# BACKEND (.env.local in /backend)
# ============================================================================

# Supabase (free tier - create at supabase.com)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Gemini API (free - 1,500 requests/day)
GEMINI_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxx

# Upstash Redis (free - 10k commands/day)
UPSTASH_REDIS_URL=https://default:xxxxx@xxxxx.upstash.io

# Resend Email (free - 3,000/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Telegram Bot (free)
TELEGRAM_BOT_TOKEN=123456789:ABCDefGHIjKlmnoPQRstuvwxyz

# App configuration
NODE_ENV=development
PORT=3000
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=30d

# File upload
MAX_FILE_SIZE=20971520  # 20MB in bytes
ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf

# Rate limiting
RATE_LIMIT_WINDOW=60000  # ms
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# FRONTEND (.env.local in /frontend)
# ============================================================================

# Backend API
EXPO_PUBLIC_API_URL=http://localhost:3000

# Supabase (same as backend)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Expo (leave as-is for development)
EXPO_PUBLIC_ENV=development
