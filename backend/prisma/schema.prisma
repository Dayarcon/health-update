// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USERS & AUTH
// ============================================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  googleId      String?  @unique
  refreshToken  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  patients        Patient[]
  notifications   Notification[]
  caregivers      Caregiver[]
  locationUpdates LocationUpdate[]

  @@index([email])
}

// ============================================================================
// PATIENTS (people whose medical info is being tracked)
// ============================================================================

model Patient {
  id        String   @id @default(cuid())
  userId    String
  name      String
  age       Int?
  gender    String?  // "male" | "female" | "other"
  relation  String?  // "self" | "parent" | "spouse" | "child" | "other"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports Report[]

  @@index([userId])
}

// ============================================================================
// MEDICAL REPORTS (uploaded documents)
// ============================================================================

model Report {
  id           String   @id @default(cuid())
  patientId    String
  reportType   String   // "prescription" | "eeg" | "lab" | "bill" | "discharge"
  imageUrl     String   // URL in Supabase storage
  fileName     String
  rawOcrText   String?  // Raw text from Gemini Vision API
  aiSummary    Json?    // Parsed JSON from Gemini LLM
  riskLevel    String?  // "low" | "medium" | "high"
  processingStatus String @default("pending") // "pending" | "processing" | "completed" | "failed"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  patient   Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicines Medicine[]
  diagnoses Diagnosis[]

  @@index([patientId])
  @@index([createdAt])
  @@index([processingStatus])
}

// ============================================================================
// MEDICINES (extracted from prescriptions)
// ============================================================================

model Medicine {
  id        String   @id @default(cuid())
  reportId  String
  name      String
  dosage    String?  // "5mg" | "500mg" etc
  frequency String?  // "once daily" | "twice daily" etc
  duration  String?  // "7 days" | "30 days" etc
  createdAt DateTime @default(now())

  // Relations
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

// ============================================================================
// DIAGNOSES (extracted from reports)
// ============================================================================

model Diagnosis {
  id        String   @id @default(cuid())
  reportId  String
  condition String   // "Anxiety" | "Epilepsy" etc
  severity  String?  // "mild" | "moderate" | "severe"
  createdAt DateTime @default(now())

  // Relations
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

// ============================================================================
// CAREGIVERS (family members receiving notifications)
// ============================================================================

model Caregiver {
  id        String   @id @default(cuid())
  userId    String
  name      String
  relation  String   // "parent" | "spouse" | "sibling" | "child" | "friend"
  email     String?
  expoToken String?
  telegramId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId])
}

// ============================================================================
// NOTIFICATIONS (alerts sent to caregivers)
// ============================================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "report_uploaded" | "report_completed" | "report_failed"
  isRead    Boolean  @default(false)
  reportId  String?
  metadata  Json?    // { patientName, riskLevel, etc }
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
}

// ============================================================================
// JOBS (for async queue processing)
// ============================================================================

model Job {
  id        String   @id @default(cuid())
  reportId  String   // Reference to the report being processed
  jobType   String   // "ocr" | "parse" | "notify"
  status    String   @default("pending") // "pending" | "processing" | "completed" | "failed"
  error     String?  // Error message if failed
  retries   Int      @default(0)
  maxRetries Int     @default(3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
  @@index([status])
  @@index([jobType])
}

// ============================================================================
// LOCATION UPDATES (real-time and historical tracking)
// ============================================================================

model LocationUpdate {
  id          String   @id @default(cuid())
  userId      String
  latitude    Float
  longitude   Float
  accuracy    Float?
  altitude    Float?
  heading     Float?
  speed       Float?
  battery     Int?
  isEmergency Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([userId, isEmergency])
}
