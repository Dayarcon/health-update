 {
    "cli": {
      "version": ">= 19.0.5",
      "appVersionSource": "remote"
    },
    "build": {
      "development": {
        "developmentClient": true,
        "distribution": "internal"
      },
      "preview": {
        "distribution": "internal"
      },
      "production": {
        "autoIncrement": true,
        "node": "22.13.0",
        "env": {
          "EXPO_USE_FAST_RESOLVER": "true"
        },
        "android": {
          "buildType": "apk",
          "gradleCommand": ":app:assembleRelease"
        }
      }
    },
    "submit": {
      "production": {}
    }
  }