    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-expo": "^11.1.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  }
